<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Sky Platform</title>
<link href="https://fonts.googleapis.com/css2?family=ADLaM+Display&display=swap" rel="stylesheet">
<style>
body{margin:0;text-align:center;font-family:'ADLaM Display',cursive;background:linear-gradient(to bottom,#87ceeb,#f4f4f4)}
canvas{display:block;margin:30px auto;border:3px solid #333;border-radius:6px;background:#87ceeb;position:relative}
#score{position:absolute;top:10px;left:10px;font-size:28px;color:#fff;font-weight:bold;text-shadow:2px 2px #000;z-index:10}
#gameOverScreen{position:absolute;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.7);display:flex;flex-direction:column;align-items:center;justify-content:center;color:#fff;font-size:32px;font-weight:bold;display:none;z-index:20}
#gameOverScreen button{margin-top:20px}
#leaderboard{position:absolute;top:10px;right:10px;color:#fff;font-size:20px;background:rgba(0,0,0,0.5);padding:10px;border-radius:6px;max-width:200px;text-align:left}
</style>
</head>
<body>
<h1>Sky Platform</h1>
<div style="position:relative; display:inline-block;">
<canvas id="game" width="700" height="500"></canvas>
<div id="score">0</div>
<div id="gameOverScreen">
  <div id="finalScore"></div>
  <button id="restartBtn">Reiniciar</button>
</div>
<div id="leaderboard">Leaderboard:</div>
</div>

<!-- Ably -->
<script src="https://cdn.ably.com/lib/ably.min-1.js"></script>

<script>
const myNum = '12345'; // tu número
const canvas=document.getElementById('game');
const ctx=canvas.getContext('2d');
const scoreDisplay=document.getElementById('score');
const gameOverScreen=document.getElementById('gameOverScreen');
const finalScore=document.getElementById('finalScore');
const restartBtn=document.getElementById('restartBtn');
const leaderboardDiv=document.getElementById('leaderboard');

let player={x:350,y:400,radius:15,vy:0,canJump:true};
let platforms=[{x:0,y:450,width:700,height:20,color:'#66ff66',scored:false}];
let keys={}; let score=0; let loop=null; let speed=4;

// --- Ably ---
const ably = new Ably.Realtime('Kp5c1A.nrnbpg:JYLdRzLwYvu4w5kXCGg3gozQTW5D0ViLa6aG0KP0nKc');
const channel = ably.channels.get('sky-platform-leaderboard');
let leaderboard = {};

// Recibir actualizaciones
channel.subscribe('update', msg=>{
    leaderboard = msg.data;
    renderLeaderboard();
});

// Enviar score
function sendScore(){
    leaderboard[myNum] = score;
    channel.publish('update', leaderboard);
}

// Render leaderboard
function renderLeaderboard(){
    let html = 'Leaderboard:<br>';
    const sorted = Object.entries(leaderboard).sort((a,b)=>b[1]-a[1]);
    sorted.forEach(([num,s])=>{ html += `${num}: ${s}<br>`; });
    leaderboardDiv.innerHTML = html;
}

// --- Juego ---
document.addEventListener('keydown',e=>{keys[e.key.toLowerCase()]=true;if(e.key.toLowerCase()==='w') jump();});
document.addEventListener('keyup',e=>{keys[e.key.toLowerCase()]=false;});
function startGame(){
    player={x:350,y:400,radius:15,vy:0,canJump:true};
    platforms=[{x:0,y:450,width:700,height:20,color:'#66ff66',scored:false}];
    score=0; speed=4; scoreDisplay.innerText=score;
    gameOverScreen.style.display='none';
    if(loop) clearInterval(loop);
    loop=setInterval(update,20);
}
function jump(){if(player.canJump){player.vy=-12;player.canJump=false;}}
function generatePlatform(){
    const width=Math.random()*200+100;
    const x=Math.random()*(canvas.width-width);
    platforms.push({x:x,y:platforms[platforms.length-1].y-100,width:width,height:20,color:'#66ff66',scored:false});
}
function update(){
    ctx.clearRect(0,0,canvas.width,canvas.height);
    if(keys['a']) player.x-=speed;
    if(keys['d']) player.x+=speed;

    player.vy+=0.5; player.y+=player.vy; player.canJump=false;

    platforms.forEach(p=>{
        ctx.fillStyle=p.color; ctx.fillRect(p.x,p.y,p.width,p.height);
        if(player.x+player.radius*2>p.x && player.x< p.x+p.width && player.y+player.radius*2>p.y && player.y+player.radius*2< player.y+player.vy+player.radius*2){
            player.y=p.y-player.radius*2; player.vy=0; player.canJump=true;
            if(!p.scored){score++; p.scored=true; p.color='#ff6666';}
        }
    });

    if(player.y<200){
        const diff=200-player.y; player.y=200;
        platforms.forEach(p=>p.y+=diff);
    }

    if(platforms[platforms.length-1].y>0) generatePlatform();

    ctx.fillStyle='blue';
    ctx.beginPath();
    ctx.arc(player.x+player.radius,player.y+player.radius,player.radius,0,Math.PI*2);
    ctx.fill();

    ctx.fillStyle='white';
    ctx.font='28px "ADLaM Display"';
    ctx.fillText('Score: '+score,10,35);

    if(player.y>canvas.height) gameOver();
}

function gameOver(){
    clearInterval(loop);
    finalScore.innerText='Score: '+score;
    gameOverScreen.style.display='flex';
    sendScore();
}
restartBtn.onclick=startGame;
startGame();
</script>
</body>
</html>
